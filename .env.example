# ============================================
# BOT NS STORE - Konfigurasi Environment
# ============================================

# Telegram Bot Token (dapatkan dari @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Digiflazz Credentials (dapatkan dari https://digiflazz.com)
DIGI_USERNAME=your_digiflazz_username
DIGI_API_KEY=your_digiflazz_api_key

# Telegram Owner ID (pisahkan dengan koma jika lebih dari satu)
# Cara cek: kirim pesan ke @userinfobot di Telegram
OWNER_ID=123456789

# Mode Testing Digiflazz (true/false)
# true = transaksi tidak benar-benar diproses (untuk testing)
# false = transaksi REAL, saldo akan terpotong!
DIGI_TESTING=false
